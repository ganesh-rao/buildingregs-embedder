{
  "$schema": "https://schema.railpack.com",
  "deploy": {
    "base": {
      "image": "ubuntu:24.04"
    },
    "aptPackages": ["ca-certificates", "libgomp1", "libstdc++6"],
    "startCommand": "./start.sh"
  },
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": ["python3 -m pip install --no-cache-dir --target /app/.python-packages boto3"]
    }
  }
}
